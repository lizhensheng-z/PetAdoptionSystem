{
  "openapi": "3.0.1",
  "info": {
    "title": "宠物领养系统 - 机构管理接口",
    "description": "宠物领养系统机构管理相关接口文档，包含机构资料管理、统计数据查看、领养记录查询等功能",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "本地开发环境"
    },
    {
      "url": "https://api.petadoption.com",
      "description": "生产环境"
    }
  ],
  "paths": {
    "/api/org/profile": {
      "get": {
        "tags": [
          "机构管理"
        ],
        "summary": "获取机构资料",
        "description": "获取当前机构的详细资料信息",
        "operationId": "getProfile",
        "security": [
          {
            "BearerAuth": [
              "org:profile:read"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ROrgProfileResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "机构管理"
        ],
        "summary": "更新机构资料",
        "description": "更新机构资料信息",
        "operationId": "updateProfile",
        "security": [
          {
            "BearerAuth": [
              "org:profile:update"
            ]
          }
        ],
        "requestBody": {
          "description": "机构资料更新请求参数",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrgProfileUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/org/statistics": {
      "get": {
        "tags": [
          "机构管理"
        ],
        "summary": "获取机构统计数据",
        "description": "获取机构的各项统计数据",
        "operationId": "getStatistics",
        "security": [
          {
            "BearerAuth": [
              "org:statistics:read"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ROrgStatisticsResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/org/adoptions": {
      "get": {
        "tags": [
          "机构管理"
        ],
        "summary": "获取领养完成记录",
        "description": "获取机构的领养完成记录列表",
        "operationId": "getAdoptionRecords",
        "security": [
          {
            "BearerAuth": [
              "org:adoptions:read"
            ]
          }
        ],
        "parameters": [
          {
            "name": "petId",
            "in": "query",
            "description": "宠物ID",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "description": "用户ID",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "month",
            "in": "query",
            "description": "月份，格式为YYYY-MM",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}$"
            }
          },
          {
            "name": "pageNo",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "排序字段",
            "required": false,
            "schema": {
              "type": "string",
              "default": "adoptedTime",
              "enum": [
                "adoptedTime",
                "petName",
                "userName"
              ]
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "排序方式",
            "required": false,
            "schema": {
              "type": "string",
              "default": "desc",
              "enum": [
                "asc",
                "desc"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RPageResultOrgAdoptionRecord"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/org/followup-reminders": {
      "get": {
        "tags": [
          "机构管理"
        ],
        "summary": "获取回访提醒",
        "description": "获取需要回访的提醒信息",
        "operationId": "getFollowupReminders",
        "security": [
          {
            "BearerAuth": [
              "org:followup:read"
            ]
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RFollowupReminderResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrgProfileResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "机构资料ID"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "关联的用户ID"
          },
          "orgName": {
            "type": "string",
            "description": "机构名称"
          },
          "licenseNo": {
            "type": "string",
            "description": "营业执照编号"
          },
          "contactName": {
            "type": "string",
            "description": "联系人姓名"
          },
          "contactPhone": {
            "type": "string",
            "description": "联系电话"
          },
          "address": {
            "type": "string",
            "description": "详细地址"
          },
          "province": {
            "type": "string",
            "description": "省份"
          },
          "city": {
            "type": "string",
            "description": "城市"
          },
          "district": {
            "type": "string",
            "description": "区县"
          },
          "lng": {
            "type": "number",
            "format": "decimal",
            "description": "经度"
          },
          "lat": {
            "type": "number",
            "format": "decimal",
            "description": "纬度"
          },
          "verifyStatus": {
            "type": "string",
            "description": "审核状态",
            "enum": [
              "PENDING",
              "APPROVED",
              "REJECTED"
            ]
          },
          "verifyRemark": {
            "type": "string",
            "description": "审核备注"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          }
        }
      },
      "OrgProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "orgName": {
            "type": "string",
            "description": "机构名称",
            "example": "爱心宠物救助中心"
          },
          "licenseNo": {
            "type": "string",
            "description": "营业执照编号",
            "example": "91110108MA01XXXXXX"
          },
          "contactName": {
            "type": "string",
            "description": "联系人姓名",
            "example": "张三"
          },
          "contactPhone": {
            "type": "string",
            "description": "联系电话（手机号或座机号）",
            "example": "13800138000"
          },
          "address": {
            "type": "string",
            "description": "详细地址",
            "example": "北京市朝阳区XXX街道"
          },
          "province": {
            "type": "string",
            "description": "省份",
            "example": "北京市"
          },
          "city": {
            "type": "string",
            "description": "城市",
            "example": "北京市"
          },
          "district": {
            "type": "string",
            "description": "区县",
            "example": "朝阳区"
          },
          "lng": {
            "type": "number",
            "format": "decimal",
            "description": "经度",
            "example": 116.4074
          },
          "lat": {
            "type": "number",
            "format": "decimal",
            "description": "纬度",
            "example": 39.9042
          }
        },
        "required": [
          "orgName",
          "contactName"
        ]
      },
      "OrgStatisticsResponse": {
        "type": "object",
        "properties": {
          "overview": {
            "type": "object",
            "description": "概况统计数据"
          },
          "applications": {
            "type": "object",
            "description": "申请统计数据"
          },
          "adoption": {
            "type": "object",
            "description": "领养统计数据"
          },
          "credibility": {
            "type": "object",
            "description": "信誉度统计数据"
          }
        }
      },
      "OrgAdoptionRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "description": "记录ID"
          },
          "petId": {
            "type": "integer",
            "format": "int64",
            "description": "宠物ID"
          },
          "petName": {
            "type": "string",
            "description": "宠物名称"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "用户ID"
          },
          "userName": {
            "type": "string",
            "description": "用户名"
          },
          "userPhone": {
            "type": "string",
            "description": "用户手机号（已脱敏）"
          },
          "userCredit": {
            "type": "object",
            "properties": {
              "score": {
                "type": "integer",
                "description": "信用分"
              },
              "level": {
                "type": "string",
                "description": "信用等级"
              }
            },
            "description": "用户信用信息"
          },
          "adoptedTime": {
            "type": "string",
            "format": "date-time",
            "description": "领养时间"
          },
          "daysSinceAdoption": {
            "type": "integer",
            "description": "领养天数"
          },
          "checkinCount": {
            "type": "integer",
            "description": "打卡次数"
          },
          "checkinRate": {
            "type": "number",
            "format": "double",
            "description": "打卡率"
          },
          "userStatus": {
            "type": "string",
            "description": "用户状态"
          },
          "riskLevel": {
            "type": "string",
            "description": "风险等级"
          }
        }
      },
      "FollowupReminderResponse": {
        "type": "object",
        "properties": {
          "overdue": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FollowupReminder"
            },
            "description": "已逾期的回访提醒"
          },
          "upcoming": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FollowupReminder"
            },
            "description": "即将到期的回访提醒"
          }
        }
      },
      "FollowupReminder": {
        "type": "object",
        "properties": {
          "petId": {
            "type": "integer",
            "format": "int64",
            "description": "宠物ID"
          },
          "petName": {
            "type": "string",
            "description": "宠物名称"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "用户ID"
          },
          "userName": {
            "type": "string",
            "description": "用户名"
          },
          "adoptedTime": {
            "type": "string",
            "format": "date-time",
            "description": "领养时间"
          },
          "daysSinceAdoption": {
            "type": "integer",
            "description": "领养天数"
          },
          "expectedCheckinDay": {
            "type": "integer",
            "description": "预期打卡天数"
          },
          "isOverdue": {
            "type": "boolean",
            "description": "是否已逾期"
          },
          "daysRemaining": {
            "type": "integer",
            "description": "剩余天数"
          },
          "riskLevel": {
            "type": "string",
            "description": "风险等级"
          }
        }
      },
      "RVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "返回数据"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "ROrgProfileResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/OrgProfileResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "ROrgStatisticsResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/OrgStatisticsResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "RPageResultOrgAdoptionRecord": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "type": "object",
            "properties": {
              "list": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/OrgAdoptionRecord"
                }
              },
              "pageNo": {
                "type": "integer"
              },
              "pageSize": {
                "type": "integer"
              },
              "total": {
                "type": "integer",
                "format": "int64"
              },
              "totalPages": {
                "type": "integer"
              }
            }
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "RFollowupReminderResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/FollowupReminderResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Authorization header using the Bearer scheme"
      }
    }
  },
  "tags": [
    {
      "name": "机构管理",
      "description": "机构相关接口"
    }
  ]
}

