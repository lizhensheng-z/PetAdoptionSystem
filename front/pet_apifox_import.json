{
  "openapi": "3.0.1",
  "info": {
    "title": "PetAdoptionSystem - Pet Management API",
    "description": "Pet Management API for Pet Adoption System",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Development Server"
    }
  ],
  "paths": {
    "/api/pets": {
      "get": {
        "summary": "获取宠物列表",
        "description": "获取公开的宠物列表，支持筛选和分页",
        "tags": ["宠物管理"],
        "parameters": [
          {
            "name": "species",
            "in": "query",
            "description": "物种（CAT/DOG/OTHER）",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "size",
            "in": "query",
            "description": "体型（S/M/L）",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "gender",
            "in": "query",
            "description": "性别（MALE/FEMALE/UNKNOWN）",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ageMin",
            "in": "query",
            "description": "最小年龄（月）",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "ageMax",
            "in": "query",
            "description": "最大年龄（月）",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "宠物状态",
            "required": false,
            "schema": {
              "type": "string",
              "default": "PUBLISHED"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "description": "经度（用于距离排序）",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lat",
            "in": "query",
            "description": "纬度（用于距离排序）",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "distanceKm",
            "in": "query",
            "description": "距离范围（公里）",
            "required": false,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "pageNo",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "description": "排序字段（distance/createTime）",
            "required": false,
            "schema": {
              "type": "string",
              "default": "distance"
            }
          },
          {
            "name": "order",
            "in": "query",
            "description": "排序方向（asc/desc）",
            "required": false,
            "schema": {
              "type": "string",
              "default": "asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取宠物列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "records": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "example": 1
                              },
                              "orgName": {
                                "type": "string",
                                "example": "爱心救助站"
                              },
                              "name": {
                                "type": "string",
                                "example": "小白"
                              },
                              "species": {
                                "type": "string",
                                "example": "CAT"
                              },
                              "breed": {
                                "type": "string",
                                "example": "英短"
                              },
                              "gender": {
                                "type": "string",
                                "example": "FEMALE"
                              },
                              "ageMonth": {
                                "type": "integer",
                                "example": 6
                              },
                              "size": {
                                "type": "string",
                                "example": "S"
                              },
                              "color": {
                                "type": "string",
                                "example": "白色"
                              },
                              "sterilized": {
                                "type": "integer",
                                "example": 1
                              },
                              "vaccinated": {
                                "type": "integer",
                                "example": 1
                              },
                              "dewormed": {
                                "type": "integer",
                                "example": 1
                              },
                              "healthDesc": {
                                "type": "string",
                                "example": "身体健康"
                              },
                              "personalityDesc": {
                                "type": "string",
                                "example": "温顺亲人"
                              },
                              "adoptRequirements": {
                                "type": "string",
                                "example": "有爱心，能定期回访"
                              },
                              "status": {
                                "type": "string",
                                "example": "PUBLISHED"
                              },
                              "lng": {
                                "type": "number",
                                "format": "double",
                                "example": 116.3972
                              },
                              "lat": {
                                "type": "number",
                                "format": "double",
                                "example": 39.9075
                              },
                              "coverUrl": {
                                "type": "string",
                                "example": "https://example.com/images/pet1.jpg"
                              },
                              "publishedTime": {
                                "type": "string",
                                "example": "2024-01-15 10:30:00"
                              },
                              "createTime": {
                                "type": "string",
                                "example": "2024-01-10 09:15:00"
                              },
                              "distanceKm": {
                                "type": "number",
                                "format": "double",
                                "example": 2.5
                              }
                            }
                          }
                        },
                        "total": {
                          "type": "integer",
                          "example": 100
                        },
                        "size": {
                          "type": "integer",
                          "example": 10
                        },
                        "current": {
                          "type": "integer",
                          "example": 1
                        },
                        "pages": {
                          "type": "integer",
                          "example": 10
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/pets/{petId}": {
      "get": {
        "summary": "获取宠物详情",
        "description": "获取指定宠物的详细信息",
        "tags": ["宠物管理"],
        "parameters": [
          {
            "name": "petId",
            "in": "path",
            "description": "宠物ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "lng",
            "in": "query",
            "description": "用户当前位置经度（用于计算距离）",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "lat",
            "in": "query",
            "description": "用户当前位置纬度（用于计算距离）",
            "required": false,
            "schema": {
              "type": "number",
              "format": "double"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取宠物详情",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "orgName": {
                          "type": "string",
                          "example": "爱心救助站"
                        },
                        "orgContactPhone": {
                          "type": "string",
                          "example": "13800138000"
                        },
                        "name": {
                          "type": "string",
                          "example": "小白"
                        },
                        "species": {
                          "type": "string",
                          "example": "CAT"
                        },
                        "breed": {
                          "type": "string",
                          "example": "英短"
                        },
                        "gender": {
                          "type": "string",
                          "example": "FEMALE"
                        },
                        "ageMonth": {
                          "type": "integer",
                          "example": 6
                        },
                        "size": {
                          "type": "string",
                          "example": "S"
                        },
                        "color": {
                          "type": "string",
                          "example": "白色"
                        },
                        "sterilized": {
                          "type": "integer",
                          "example": 1
                        },
                        "vaccinated": {
                          "type": "integer",
                          "example": 1
                        },
                        "dewormed": {
                          "type": "integer",
                          "example": 1
                        },
                        "healthDesc": {
                          "type": "string",
                          "example": "身体健康"
                        },
                        "personalityDesc": {
                          "type": "string",
                          "example": "温顺亲人"
                        },
                        "adoptRequirements": {
                          "type": "string",
                          "example": "有爱心，能定期回访"
                        },
                        "status": {
                          "type": "string",
                          "example": "PUBLISHED"
                        },
                        "lng": {
                          "type": "number",
                          "format": "double",
                          "example": 116.3972
                        },
                        "lat": {
                          "type": "number",
                          "format": "double",
                          "example": 39.9075
                        },
                        "coverUrl": {
                          "type": "string",
                          "example": "https://example.com/images/pet1.jpg"
                        },
                        "mediaUrls": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "example": "https://example.com/images/pet1_1.jpg"
                          }
                        },
                        "tags": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer",
                                "example": 1
                              },
                              "name": {
                                "type": "string",
                                "example": "亲人"
                              },
                              "type": "string",
                              "example": "PERSONALITY"
                            }
                          }
                        },
                        "publishedTime": {
                          "type": "string",
                          "example": "2024-01-15 10:30:00"
                        },
                        "createTime": {
                          "type": "string",
                          "example": "2024-01-10 09:15:00"
                        },
                        "distanceKm": {
                          "type": "number",
                          "format": "double",
                          "example": 2.5
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/org/pets": {
      "post": {
        "summary": "创建宠物档案",
        "description": "机构创建新的宠物档案",
        "tags": ["宠物管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["species", "coverUrl"],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "宠物名字/昵称",
                    "example": "小花"
                  },
                  "species": {
                    "type": "string",
                    "description": "物种（CAT/DOG/OTHER）",
                    "example": "CAT"
                  },
                  "breed": {
                    "type": "string",
                    "description": "品种",
                    "example": "田园猫"
                  },
                  "gender": {
                    "type": "string",
                    "description": "性别（MALE/FEMALE/UNKNOWN）",
                    "example": "FEMALE"
                  },
                  "ageMonth": {
                    "type": "integer",
                    "description": "年龄（月）",
                    "example": 6
                  },
                  "size": {
                    "type": "string",
                    "description": "体型（S/M/L）",
                    "example": "S"
                  },
                  "color": {
                    "type": "string",
                    "description": "毛色/颜色",
                    "example": "三花"
                  },
                  "sterilized": {
                    "type": "integer",
                    "description": "是否绝育（0否1是）",
                    "example": 0
                  },
                  "vaccinated": {
                    "type": "integer",
                    "description": "是否疫苗（0否1是）",
                    "example": 1
                  },
                  "dewormed": {
                    "type": "integer",
                    "description": "是否驱虫（0否1是）",
                    "example": 1
                  },
                  "healthDesc": {
                    "type": "string",
                    "description": "健康描述",
                    "example": "健康活泼"
                  },
                  "personalityDesc": {
                    "type": "string",
                    "description": "性格描述",
                    "example": "活泼好动，喜欢与人互动"
                  },
                  "adoptRequirements": {
                    "type": "string",
                    "description": "领养要求",
                    "example": "有养猫经验，能定期回访"
                  },
                  "coverUrl": {
                    "type": "string",
                    "description": "封面图片URL",
                    "example": "https://example.com/images/pet_cover.jpg"
                  },
                  "mediaUrls": {
                    "type": "array",
                    "description": "媒体文件URL数组",
                    "items": {
                      "type": "string",
                      "example": "https://example.com/images/pet1.jpg"
                    }
                  },
                  "tagIds": {
                    "type": "array",
                    "description": "标签ID数组",
                    "items": {
                      "type": "integer",
                      "example": 1
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功创建宠物档案",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "status": {
                          "type": "string",
                          "example": "DRAFT"
                        },
                        "auditStatus": {
                          "type": "string",
                          "example": "NONE"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}