{
  "openapi": "3.0.1",
  "info": {
    "title": "宠物领养系统 - 登录认证接口",
    "description": "宠物领养系统登录认证相关接口文档，包含用户登录、注册、登出等功能",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8081",
      "description": "本地开发环境"
    },
    {
      "url": "https://api.petadoption.com",
      "description": "生产环境"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": [
          "认证管理"
        ],
        "summary": "用户登录",
        "description": "用户登录接口，返回JWT令牌",
        "operationId": "login",
        "requestBody": {
          "description": "登录请求参数",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RLoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "401": {
            "description": "用户名或密码错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "tags": [
          "认证管理"
        ],
        "summary": "用户注册",
        "description": "用户注册接口",
        "operationId": "register",
        "requestBody": {
          "description": "注册请求参数",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RUserEntity"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh-token": {
      "post": {
        "tags": [
          "认证管理"
        ],
        "summary": "刷新令牌",
        "description": "使用刷新令牌获取新的访问令牌",
        "operationId": "refreshToken",
        "requestBody": {
          "description": "刷新令牌请求参数",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "刷新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RLoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "刷新令牌无效",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "认证管理"
        ],
        "summary": "用户登出",
        "description": "用户登出接口，将当前token加入黑名单",
        "operationId": "logout",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "登出成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": [
          "认证管理"
        ],
        "summary": "获取当前用户信息",
        "description": "获取当前登录用户的详细信息",
        "operationId": "getCurrentUserInfo",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RUserInfoResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/profile": {
      "put": {
        "tags": [
          "认证管理"
        ],
        "summary": "修改个人资料",
        "description": "修改当前用户的个人资料",
        "operationId": "updateProfile",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "description": "个人资料更新请求参数",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserProfileUpdateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "修改成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "admin",
            "description": "用户名"
          },
          "password": {
            "type": "string",
            "example": "123456",
            "description": "密码"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "example": "testuser",
            "description": "用户名，长度必须在3-20个字符之间"
          },
          "password": {
            "type": "string",
            "example": "123456",
            "description": "密码，长度必须在6-20个字符之间"
          },
          "phone": {
            "type": "string",
            "example": "13800138000",
            "description": "手机号"
          },
          "email": {
            "type": "string",
            "example": "test@example.com",
            "description": "邮箱"
          },
          "role": {
            "type": "string",
            "example": "USER",
            "description": "用户角色：USER/ORG/ADMIN"
          }
        },
        "required": [
          "username",
          "password"
        ]
      },
      "RefreshTokenRequest": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGc...",
            "description": "刷新令牌"
          }
        },
        "required": [
          "refreshToken"
        ]
      },
      "UserProfileUpdateRequest": {
        "type": "object",
        "properties": {
          "avatar": {
            "type": "string",
            "example": "https://example.com/avatar.jpg",
            "description": "头像URL"
          },
          "phone": {
            "type": "string",
            "example": "13800138000",
            "description": "手机号"
          },
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "邮箱"
          },
          "preference": {
            "type": "object",
            "properties": {
              "species": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "CAT",
                  "DOG"
                ],
                "description": "宠物种类偏好"
              },
              "sizePreference": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "M",
                  "L"
                ],
                "description": "体型偏好"
              },
              "ageRange": {
                "type": "array",
                "items": {
                  "type": "integer"
                },
                "example": [
                  12,
                  120
                ],
                "description": "年龄范围(月)"
              },
              "personality": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "亲人",
                  "活泼"
                ],
                "description": "性格偏好"
              },
              "requiredHealth": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "example": [
                  "已绝育",
                  "已疫苗"
                ],
                "description": "健康要求"
              },
              "city": {
                "type": "string",
                "example": "北京",
                "description": "城市"
              }
            },
            "description": "用户偏好设置"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "访问令牌"
          },
          "refreshToken": {
            "type": "string",
            "description": "刷新令牌"
          },
          "expiresIn": {
            "type": "integer",
            "description": "令牌有效期(秒)"
          },
          "tokenType": {
            "type": "string",
            "description": "令牌类型",
            "default": "Bearer"
          },
          "userId": {
            "type": "integer",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "role": {
            "type": "string",
            "description": "用户角色"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "用户权限列表"
          },
          "avatar": {
            "type": "string",
            "description": "头像URL"
          }
        }
      },
      "UserInfoResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "integer",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "role": {
            "type": "string",
            "description": "用户角色"
          },
          "avatar": {
            "type": "string",
            "description": "头像URL"
          },
          "phone": {
            "type": "string",
            "description": "手机号"
          },
          "email": {
            "type": "string",
            "description": "邮箱"
          },
          "status": {
            "type": "string",
            "description": "用户状态"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "权限列表"
          }
        }
      },
      "UserEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "用户ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "phone": {
            "type": "string",
            "description": "手机号"
          },
          "email": {
            "type": "string",
            "description": "邮箱"
          },
          "role": {
            "type": "string",
            "description": "用户角色"
          },
          "status": {
            "type": "string",
            "description": "用户状态"
          },
          "createTime": {
            "type": "string",
            "format": "date-time",
            "description": "创建时间"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time",
            "description": "更新时间"
          },
          "deleted": {
            "type": "integer",
            "description": "删除标记"
          }
        }
      },
      "RVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "type": "object",
            "nullable": true,
            "description": "返回数据"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "RLoginResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/LoginResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "RUserEntity": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/UserEntity"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      },
      "RUserInfoResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "状态码"
          },
          "message": {
            "type": "string",
            "description": "响应消息"
          },
          "data": {
            "$ref": "#/components/schemas/UserInfoResponse"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "时间戳"
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT Authorization header using the Bearer scheme"
      }
    }
  },
  "tags": [
    {
      "name": "认证管理",
      "description": "用户认证相关接口"
    }
  ]
}